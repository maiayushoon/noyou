# =============================================================================
# NoYou — PRODUCTION environment template
# =============================================================================
# Copy this file to ".env" next to docker-compose.prod.yml and fill in real
# values. NEVER commit your real .env. Every line is documented; defaults that
# are safe to keep are noted as such.
#
#   cp .env.production.example .env
#   # then edit .env
#
# See DEPLOYMENT.md for the full go-live walkthrough.
# -----------------------------------------------------------------------------

# --- Environment ------------------------------------------------------------
# "production" turns on production behaviour (e.g. requiring real config).
ENVIRONMENT=production

# --- Database ---------------------------------------------------------------
# Postgres connection string used by the app (SQLAlchemy + psycopg2 driver).
# For the bundled docker-compose Postgres, the host is the compose service
# name "db" and the credentials must match POSTGRES_* below.
DATABASE_URL=postgresql+psycopg2://noyou:CHANGE_ME_STRONG_DB_PASSWORD@db:5432/noyou

# Credentials for the bundled Postgres container (docker-compose.prod.yml).
# POSTGRES_PASSWORD is REQUIRED — the stack refuses to start without it.
# Keep these in sync with DATABASE_URL above.
POSTGRES_USER=noyou
POSTGRES_PASSWORD=CHANGE_ME_STRONG_DB_PASSWORD
POSTGRES_DB=noyou

# --- Auth / security --------------------------------------------------------
# Generate a unique 64-hex-char secret. DO NOT reuse the dev default.
#   python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=CHANGE_ME_RUN_python_-c_import_secrets_print_secrets.token_hex_32
# JWT signing algorithm and access-token lifetime (minutes). Defaults are fine.
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# --- Public URLs / domain ---------------------------------------------------
# Your public hostname. Used by Caddy for automatic HTTPS AND by the app to
# build verification / password-reset links in emails.
DOMAIN=app.example.com
# Email address Let's Encrypt uses for cert-expiry notices (optional).
ACME_EMAIL=admin@example.com
# Full base URL the app uses to construct links in emails. Must be the public
# HTTPS URL your users hit (typically https://$DOMAIN).
FRONTEND_URL=https://app.example.com

# --- CORS -------------------------------------------------------------------
# Comma-separated list of origins allowed to call the API from a browser.
# In production set this to your real site origin(s) only — NOT "*".
CORS_ORIGINS=https://app.example.com

# --- Email verification & password reset ------------------------------------
# Set to true ONLY after SMTP below is verified working, otherwise new users
# can't confirm their email. Start false, flip to true once email sends.
REQUIRE_EMAIL_VERIFICATION=false
# How long verification / reset links stay valid.
EMAIL_TOKEN_EXPIRE_HOURS=24
RESET_TOKEN_EXPIRE_HOURS=2

# --- Notifications / SMTP ---------------------------------------------------
# "email" routes alerts + verification/reset mail through SMTP; "console" just
# logs them (useful before SMTP is set up).
NOTIFY_CHANNEL=email
# SMTP provider details. Examples:
#   Resend:   host smtp.resend.com   port 587  user "resend"  password=<API key>
#   SendGrid: host smtp.sendgrid.net port 587  user "apikey"  password=<API key>
#   Mailgun:  host smtp.mailgun.org  port 587  user/pass from Mailgun dashboard
#   Gmail:    host smtp.gmail.com    port 587  user <address> password=<App Password>
SMTP_HOST=smtp.resend.com
SMTP_PORT=587
SMTP_USER=resend
SMTP_PASSWORD=CHANGE_ME_SMTP_API_KEY_OR_PASSWORD
# The "From" address. Must be a domain/address your SMTP provider lets you send.
SMTP_FROM=alerts@example.com

# --- Rate limiting ----------------------------------------------------------
# Requests/minute caps. auth_* applies to login/register/reset to slow abuse.
RATE_LIMIT_PER_MINUTE=60
AUTH_RATE_LIMIT_PER_MINUTE=10

# --- AI analysis ------------------------------------------------------------
# "rule_based" needs no keys and works out of the box. Switch to "llm" only if
# you provide a provider key below.
ANALYZER=rule_based
# LLM_PROVIDER selects which key is used when ANALYZER=llm: openai | anthropic | huggingface
LLM_PROVIDER=openai
# Optional — only needed when ANALYZER=llm.
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
HUGGINGFACE_API_KEY=

# --- Data-source connectors -------------------------------------------------
# Comma list of sources to scan. Use real, keyless/free-tier sources in prod.
# "web,hackernews,reddit_public" require no paid API keys. The "demo" connector
# is a fallback that generates fake data — remove it for real deployments.
CONNECTORS=web,hackernews,reddit_public
# How often (minutes) the background scheduler runs scans.
SCAN_INTERVAL_MINUTES=360

# Google Custom Search (optional, free 100 queries/day) — enables the "google"
# connector. Create a key + a Programmable Search Engine (CSE) id.
GOOGLE_API_KEY=
GOOGLE_CSE_ID=

# Other optional source credentials (only needed if you add these connectors):
TWITTER_BEARER_TOKEN=
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USER_AGENT=noyou/1.0
YOUTUBE_API_KEY=

# --- Demo seeding -----------------------------------------------------------
# MUST be false in production so no demo account/data is created.
SEED_DEMO=false

# --- Gunicorn (process tuning, optional) ------------------------------------
# Number of worker processes. Leave unset to use (2*CPU)+1, or pin it on small
# hosts (e.g. 2 or 3). See DEPLOYMENT.md scaling notes.
# WEB_CONCURRENCY=3
# GUNICORN_TIMEOUT=120
