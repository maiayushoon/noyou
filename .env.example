# ─────────────────────────────────────────────────────────────────────────────
# NoYou configuration. Copy to backend/.env and edit. Every value has a safe
# default — an empty file runs the full product in offline demo mode.
# ─────────────────────────────────────────────────────────────────────────────

# --- Core ---
# development | production. In production the app refuses to boot with a default
# SECRET_KEY and enables HSTS.
ENVIRONMENT=development

# Public base URL of the frontend — used to build email verification/reset links.
FRONTEND_URL=http://localhost:8000

# SQLite (default, zero setup) or Postgres, e.g.
#   postgresql+psycopg2://user:pass@localhost:5432/noyou
DATABASE_URL=sqlite:///./noyou.db

# JWT signing key. CHANGE THIS IN PRODUCTION (e.g. `python -c "import secrets;print(secrets.token_hex(32))"`).
SECRET_KEY=change-me-in-production
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# Comma-separated list of allowed CORS origins (frontend hosts).
CORS_ORIGINS=http://localhost:8000,http://localhost:3000,http://127.0.0.1:8000

# --- Public signup: email verification & password reset ---
# When true, new users must click an emailed link before they can sign in.
# Leave false until SMTP (below) is configured, so signups aren't blocked.
REQUIRE_EMAIL_VERIFICATION=false
EMAIL_TOKEN_EXPIRE_HOURS=24
RESET_TOKEN_EXPIRE_HOURS=2

# --- Rate limiting (per client IP, per endpoint) ---
RATE_LIMIT_PER_MINUTE=60
AUTH_RATE_LIMIT_PER_MINUTE=10

# --- AI analysis ---
# rule_based (offline, no keys) | llm (needs a provider key below)
ANALYZER=rule_based
LLM_PROVIDER=openai            # openai | anthropic | huggingface
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
HUGGINGFACE_API_KEY=

# --- Data source connectors ---
# Comma list of sources to scan. Three connectors return REAL data with NO API keys
# (best-effort, may be rate-limited):
#   web            -> DuckDuckGo HTML search
#   hackernews     -> Hacker News (Algolia search API)
#   reddit_public  -> Reddit public search.json
# Keyed connectors activate when their credentials are set below:
#   google, twitter, reddit, youtube, linkedin
# demo is synthetic and always works (good as a fallback).
# Dev default is demo; recommended for a live launch:
#   CONNECTORS=web,hackernews,reddit_public,demo
CONNECTORS=demo

# Google Programmable Search (Custom Search Engine)
GOOGLE_API_KEY=
GOOGLE_CSE_ID=

# X / Twitter API v2
TWITTER_BEARER_TOKEN=

# Reddit
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USER_AGENT=noyou/1.0

# YouTube Data API v3
YOUTUBE_API_KEY=

# --- Background scanning ---
# How often automated scans run, in minutes. 0 disables the scheduler.
SCAN_INTERVAL_MINUTES=360

# --- Demo seeding ---
SEED_DEMO=true
DEMO_EMAIL=demo@noyou.app
DEMO_PASSWORD=demo12345

# --- Notifications (optional) ---
NOTIFY_CHANNEL=console          # console | email
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=alerts@noyou.app
