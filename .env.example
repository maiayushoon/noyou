# ─────────────────────────────────────────────────────────────────────────────
# NoYou configuration. Copy to backend/.env and edit. Every value has a safe
# default — an empty file runs the full product in offline demo mode.
# ─────────────────────────────────────────────────────────────────────────────

# --- Core ---
# development | production. In production the app refuses to boot with a default
# SECRET_KEY and enables HSTS.
ENVIRONMENT=development

# Public base URL of the frontend — used to build email verification/reset links.
FRONTEND_URL=http://localhost:8000

# SQLite (default, zero setup) or Postgres, e.g.
#   postgresql+psycopg2://user:pass@localhost:5432/noyou
DATABASE_URL=sqlite:///./noyou.db

# JWT signing key. CHANGE THIS IN PRODUCTION (e.g. `python -c "import secrets;print(secrets.token_hex(32))"`).
SECRET_KEY=change-me-in-production
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# Comma-separated list of allowed CORS origins (frontend hosts).
CORS_ORIGINS=http://localhost:8000,http://localhost:3000,http://127.0.0.1:8000

# --- Public signup: email verification & password reset ---
# When true, new users must click an emailed link before they can sign in.
# Leave false until SMTP (below) is configured, so signups aren't blocked.
REQUIRE_EMAIL_VERIFICATION=false
EMAIL_TOKEN_EXPIRE_HOURS=24
RESET_TOKEN_EXPIRE_HOURS=2

# --- Rate limiting (per client IP, per endpoint) ---
RATE_LIMIT_PER_MINUTE=60
AUTH_RATE_LIMIT_PER_MINUTE=10

# --- AI analysis ---
# rule_based (offline lexicon, no keys, default)
#   | trained   (NoYou's own TF-IDF + logistic-regression sentiment model — free,
#                CPU-only, no keys; hybridizes with rule_based for risk. Falls back
#                to rule_based until trained, so it's always safe.
#                train with: python -m app.ml.train  (run from the backend/ dir))
#   | llm       (needs a provider key below)
ANALYZER=rule_based
LLM_PROVIDER=openai            # openai | anthropic | huggingface
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
HUGGINGFACE_API_KEY=
# Directory holding the trained sentiment model (sentiment.joblib).
# Empty => the package's app/ml/models/ dir. Only used when ANALYZER=trained.
ML_MODEL_DIR=

# --- Data source connectors ---
# Comma list of sources to scan. Five connectors return REAL data with NO API keys
# (best-effort, may be rate-limited):
#   web            -> DuckDuckGo HTML search
#   hackernews     -> Hacker News (Algolia search API)
#   reddit_public  -> Reddit public search.json
#   googlenews     -> Google News RSS  (real, dated Google News, NO key)
#   bing           -> Bing News RSS    (real, dated Bing News, NO key)
# Keyed connectors activate when their credentials are set below:
#   google, twitter, reddit, youtube, linkedin
# demo is synthetic and always works (good as a fallback).
# Dev default is demo; recommended for a live launch:
#   CONNECTORS=web,hackernews,reddit_public,googlenews,bing
CONNECTORS=demo

# Google Programmable Search (Custom Search Engine)
GOOGLE_API_KEY=
GOOGLE_CSE_ID=

# X / Twitter API v2
TWITTER_BEARER_TOKEN=

# Reddit
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USER_AGENT=noyou/1.0

# YouTube Data API v3
YOUTUBE_API_KEY=

# --- Connections (OAuth account-linking) ---
# Let a user authorize NoYou to read their OWN posts, which then flow through the
# normal scan pipeline. These are SEPARATE from the public-search keys above (e.g.
# GOOGLE_API_KEY, REDDIT_CLIENT_ID). Each provider's redirect URI must be set to
#   {FRONTEND_URL}/api/v1/connections/{provider}/callback
# in that provider's developer console, and FRONTEND_URL must be HTTPS in production.
# All keys are optional — a provider's card simply shows as "not configured" until
# its credentials are present. Linking is gated behind a paid plan.
#
# Mastodon needs NO credentials: NoYou self-registers an app per instance at connect
# time; the user only enters their instance URL (e.g. https://mastodon.social).
# Optionally override the registered app name (defaults to "NoYou").
MASTODON_APP_NAME=NoYou
#
# Google / YouTube: Google Cloud project with "YouTube Data API v3" enabled and an
# OAuth 2.0 Web client. Distinct from GOOGLE_API_KEY/GOOGLE_CSE_ID above.
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
#
# Reddit: a "web app" client at reddit.com/prefs/apps (pre-approval required under
# the Responsible Builder Policy). Distinct from REDDIT_CLIENT_ID/SECRET above.
REDDIT_OAUTH_CLIENT_ID=
REDDIT_OAUTH_CLIENT_SECRET=
#
# Threads (Meta): a Meta Business app with the Threads product added.
THREADS_APP_ID=
THREADS_APP_SECRET=
#
# Instagram (Meta): a Meta app with Instagram Login configured. End users must have
# a Professional (Business/Creator) IG account.
INSTAGRAM_APP_ID=
INSTAGRAM_APP_SECRET=
#
# Optional: pin a Fernet key (urlsafe-base64 of 32 bytes) so token encryption is
# decoupled from SECRET_KEY (rotating SECRET_KEY otherwise invalidates stored
# tokens, forcing users to re-link). Empty => derived from SECRET_KEY.
TOKEN_ENCRYPTION_KEY=

# --- Background scanning ---
# How often automated scans run, in minutes. 0 disables the scheduler.
SCAN_INTERVAL_MINUTES=360

# --- Demo seeding ---
SEED_DEMO=true
DEMO_EMAIL=demo@noyou.app
DEMO_PASSWORD=demo12345

# --- Notifications (optional) ---
NOTIFY_CHANNEL=console          # console | email | resend
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=alerts@noyou.app
# Resend (https://resend.com) — easiest production email. Set NOTIFY_CHANNEL=resend.
RESEND_API_KEY=

# --- AI brain (optional) — real LLM analysis (also enables multi-lingual) ---
# Set ANALYZER=llm and one provider key. LLM_PROVIDER = openai | anthropic | huggingface
# (ANALYZER / LLM_PROVIDER / *_API_KEY are in the AI analysis section above.)

# --- Stripe billing (optional) ---
# From https://dashboard.stripe.com — create Products/Prices for Pro & Premium and
# paste their price IDs. Webhook: point Stripe to POST {API}/api/v1/billing/webhook
# and paste the signing secret. Leave blank to run without billing (plan gating still works).
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_PRO=
STRIPE_PRICE_PREMIUM=
# STRIPE_PRICE_ENTERPRISE=
